# setup-vps.sh — .env.example

# Linux user to execute agent
AGENT_USER=""

# Personal computer's Syncthing Device ID
REMOTE_DEVICE_ID=""

# Obsidian Vault's Syncthing Folder ID
VAULT_ID=""

# Vault path "inside" Syncthing container(change if only need to)
VAULT_PATH="/data/vault"

# Discord Bot Token
DISCORD_BOT_TOKEN=""

# Claude Code OAuth Token
# Get token from personal computer by using: claude setup-token
CLAUDE_OAUTH_TOKEN=""

# Timezone
TIMEZONE="Asia/Taipei"
