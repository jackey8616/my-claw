# setup-vps.sh — .env.example

# Linux user to execute agent
AGENT_USER=""

# Cloudflare R2 — vault sync (replaces Syncthing)
# Cloudflare Account ID (R2 dashboard sidebar)
R2_ACCOUNT_ID=""
# vps-rclone API token credentials
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
# R2 bucket name
R2_BUCKET_NAME=""
# Remotely Save E2E encryption password (shared with Mac & iPhone)
R2_E2E_PASSWORD=""

# Discord Bot Token
DISCORD_BOT_TOKEN=""

# Timezone
TIMEZONE="Asia/Taipei"

OLLAMA_API_KEY=""

# GitHub Personal Access Token (optional, for GitHub skill + GPG signing)
# Scopes: repo + write:gpg_key
GH_TOKEN=""
